{
  "opencollection": "1.0.0",
  "info": {
    "name": "Chase Account and Customer Information API",
    "version": "5.2"
  },
  "request": {
    "auth": {
      "type": "oauth2",
      "flow": "authorization_code",
      "authorizationUrl": "https://api.chase.com/oauth2/authorize",
      "accessTokenUrl": "https://api.chase.com/oauth2/token",
      "credentials": {
        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Accounts",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List accessible accounts",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.chase.com/aggregation/fdx/accounts"
          },
          "docs": "List accessible accounts"
        },
        {
          "info": {
            "name": "Get account details",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.chase.com/aggregation/fdx/accounts/:accountId",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get account details"
        }
      ]
    },
    {
      "info": {
        "name": "Transactions",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List account transactions",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.chase.com/aggregation/fdx/accounts/:accountId/transactions",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              },
              {
                "name": "startTime",
                "value": "",
                "type": "query"
              },
              {
                "name": "endTime",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List account transactions"
        }
      ]
    },
    {
      "info": {
        "name": "Statements",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List account statements",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.chase.com/aggregation/fdx/accounts/:accountId/statements",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "List account statements"
        }
      ]
    },
    {
      "info": {
        "name": "Tax Forms",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List tax forms for an account",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.chase.com/aggregation/fdx/accounts/:accountId/tax-forms",
            "params": [
              {
                "name": "accountId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "List tax forms for an account"
        }
      ]
    },
    {
      "info": {
        "name": "Customers",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get the current authenticated customer",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.chase.com/aggregation/fdx/customers/current"
          },
          "docs": "Get the current authenticated customer"
        }
      ]
    }
  ],
  "bundled": true
}