        "clientId": "{{clientId}}",
        "clientSecret": "{{clientSecret}}"
      }
    }
  },
  "items": [
    {
      "info": {
        "name": "Rewards Balance",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Retrieve a rewards balance for a tokenized card",
