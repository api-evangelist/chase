          },
          "http": {
            "method": "POST",
            "url": "https://api.chase.com/loyalty/rewards-balance/balances",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Retrieve a rewards balance for a tokenized card"
        }
      ]
    }
  ],
  "bundled": true
}